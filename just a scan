#!/bin/bash
# debug-wifi.sh - Run this with your known password

SSID="YOUR_WIFI_NAME"  # Replace with your actual SSID
PASSWORD="YOUR_PASSWORD"  # Replace with your actual password
INTERFACE="wlp4s0"

echo "=== DEBUG: WiFi Connection Test ==="
echo "SSID: $SSID"
echo "Interface: $INTERFACE"
echo "==================================="

# Disconnect everything
echo "1. Disconnecting from all networks..."
sudo nmcli device disconnect "$INTERFACE" 2>/dev/null
sudo nmcli radio wifi off
sleep 2
sudo nmcli radio wifi on
sleep 3

# Try to connect
echo "2. Attempting connection..."
sudo nmcli device wifi connect "$SSID" password "$PASSWORD" ifname "$INTERFACE"
CONNECT_RESULT=$?
echo "nmcli connect result: $CONNECT_RESULT"

# Wait and check status every second for 10 seconds
echo "3. Monitoring connection status for 10 seconds..."
for i in {1..10}; do
    echo "--- Second $i ---"
    
    # Check various connection indicators
    echo "iwgetid: '$(iwgetid -r 2>/dev/null)'"
    echo "nmcli device status:"
    nmcli device status | grep "$INTERFACE"
    echo "IP address: $(ip -4 addr show "$INTERFACE" 2>/dev/null | grep inet)"
    echo "Connection state:"
    nmcli -f GENERAL.STATE dev show "$INTERFACE" 2>/dev/null | grep GENERAL.STATE
    
    sleep 1
done

echo "4. Final connection info:"
nmcli connection show --active
echo ""
echo "5. DHCP info:"
cat /var/lib/dhcp/dhclient.leases 2>/dev/null | tail -20
