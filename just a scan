#!/bin/bash
# diagnose-wifi.sh

SSID="YOUR_WIFI_NAME"  # Replace with your actual SSID
PASSWORD="YOUR_PASSWORD"  # Replace with your actual password
INTERFACE="wlp4s0"

echo "=== WiFi Connection Diagnostic ==="
echo "SSID: $SSID"
echo "Interface: $INTERFACE"
echo "=================================="

# Disconnect everything
echo "1. Disconnecting..."
sudo nmcli device disconnect "$INTERFACE" 2>/dev/null
sudo nmcli radio wifi off
sleep 2
sudo nmcli radio wifi on
sleep 3

# Try to connect with known good password
echo "2. Attempting connection with known good password..."
sudo nmcli device wifi connect "$SSID" password "$PASSWORD" ifname "$INTERFACE" &
CONN_PID=$!

# Monitor connection status for 20 seconds
echo "3. Monitoring connection status for 20 seconds..."
echo "Time,iwgetid,IP Address,nmcli_state,active_connections" > connection_log.csv

for i in {1..20}; do
    CURRENT_SSID=$(iwgetid -r 2>/dev/null)
    IP_ADDR=$(ip -4 addr show "$INTERFACE" 2>/dev/null | grep -oP '(?<=inet\s)\d+\.\d+\.\d+\.\d+')
    NMCLI_STATE=$(nmcli -f GENERAL.STATE dev show "$INTERFACE" 2>/dev/null | grep GENERAL.STATE | cut -d: -f2- | xargs)
    ACTIVE_CONNS=$(nmcli -t -f NAME,DEVICE connection show --active 2>/dev/null | paste -sd '|' -)
    
    echo "$i,$CURRENT_SSID,$IP_ADDR,$NMCLI_STATE,$ACTIVE_CONNS"
    echo "$i,$CURRENT_SSID,$IP_ADDR,$NMCLI_STATE,$ACTIVE_CONNS" >> connection_log.csv
    
    sleep 1
done

# Final status
echo ""
echo "4. Final connection status:"
echo "=========================="
echo "Current SSID: $(iwgetid -r 2>/dev/null)"
echo "IP Address: $(ip -4 addr show "$INTERFACE" 2>/dev/null | grep inet)"
echo ""
echo "Active connections:"
nmcli connection show --active
echo ""
echo "Device status:"
nmcli device status | grep "$INTERFACE"

# Cleanup
sudo kill $CONN_PID 2>/dev/null
